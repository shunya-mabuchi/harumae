    "policy": {
      "action": "confirm",
      "severity": "medium",
      "canSendRaw": true,
      "requiresSanitization": false
    },
    "generalizedIncludes": ["[注意情報]", "[金額情報]", "[URL]"],
    "generalizedExcludes": ["300万円", "月額80万円", "staging.example.local"],
    "maskedIncludes": ["[CONFIDENTIAL_TEXT_1]", "[AMOUNT_1]", "[AMOUNT_2]", "[INTERNAL_URL_1]"],
