{
  "name": "ai-mae-check",
  "private": true,
  "version": "0.1.1",
  "license": "MIT",
  "packageManager": "pnpm@10.12.1",
  "type": "module",
  "scripts": {
    "dev": "pnpm dev:demo",
    "dev:extension": "pnpm --filter @ai-mae-check/core build && pnpm --filter @ai-mae-check/llm build && pnpm --filter @ai-mae-check/extension dev",
    "dev:demo": "pnpm --filter @ai-mae-check/core build && pnpm --filter @ai-mae-check/llm build && pnpm --filter @ai-mae-check/demo dev",
    "build": "pnpm -r --sort build",
    "build:extension": "pnpm --filter @ai-mae-check/core build && pnpm --filter @ai-mae-check/llm build && pnpm --filter @ai-mae-check/extension build",
    "build:demo": "pnpm --filter @ai-mae-check/core build && pnpm --filter @ai-mae-check/llm build && pnpm --filter @ai-mae-check/demo build",
    "build:worker": "pnpm --filter @ai-mae-check/worker build",
    "package:extension": "node scripts/package-extension-release.mjs",
    "test": "pnpm --filter @ai-mae-check/core test && pnpm --filter @ai-mae-check/llm test && pnpm --filter @ai-mae-check/demo test && pnpm --filter @ai-mae-check/extension test && pnpm --filter @ai-mae-check/worker test",
    "test:core": "pnpm --filter @ai-mae-check/core test",
    "test:demo": "pnpm --filter @ai-mae-check/demo test",
    "test:llm": "pnpm --filter @ai-mae-check/llm test",
    "test:worker": "pnpm --filter @ai-mae-check/worker test",
    "test:e2e": "pnpm --filter @ai-mae-check/demo test:e2e",
    "lint": "pnpm typecheck",
    "typecheck": "pnpm -r --sort typecheck",
    "assets:brand": "node scripts/generate-brand-assets.mjs",
    "rules:keygen": "node scripts/generate-rule-keypair.mjs",
    "qa:public-repo": "node scripts/check-public-repo-safety.mjs",
    "qa:public-docs": "node scripts/check-public-docs-sync.mjs",
    "qa:privacy-regression": "node scripts/check-privacy-regression.mjs",
    "qa:performance-budget": "node scripts/check-performance-budget-doc.mjs",
    "qa:webllm-model-policy": "node scripts/check-webllm-model-policy.mjs",
    "qa:webllm-compatibility": "node scripts/check-webllm-compatibility-doc.mjs",
    "qa:rule-catalog": "node scripts/check-rule-catalog.mjs",
    "qa:extension:e2e-harness": "node scripts/check-extension-e2e-harness-doc.mjs",
    "qa:dependency-policy": "node scripts/check-dependency-policy.mjs",
    "qa:release-policy": "node scripts/check-release-policy.mjs",
    "qa:issue-pr-workflow": "node scripts/check-issue-pr-workflow.mjs",
    "qa:demo:seo": "node scripts/check-demo-seo.mjs",
    "qa:portfolio-case-study": "node scripts/check-portfolio-case-study.mjs",
    "qa:extension:size": "node scripts/check-extension-size-budget.mjs",
    "qa:extension:manifest": "node scripts/check-extension-manifest.mjs",
    "qa:chrome-store": "node scripts/check-chrome-store-readiness.mjs",
    "bench:rules": "vitest run scripts/bench-rule-detection.test.ts --reporter=verbose"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/chrome": "^0.0.326",
    "@types/node": "^22.15.29",
    "@vitejs/plugin-react": "^4.5.2",
    "@wxt-dev/module-react": "^1.1.3",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.2.4",
    "wxt": "^0.20.6"
  }
}
