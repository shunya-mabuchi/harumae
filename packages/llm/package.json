{
  "name": "@harumae/llm",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./worker": {
      "types": "./dist/worker.d.ts",
      "import": "./dist/worker.js"
    }
  },
  "scripts": {
    "build": "pnpm --filter @harumae/core build && tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "pnpm --filter @harumae/core build && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@harumae/core": "workspace:*",
    "@mlc-ai/web-llm": "^0.2.79"
  }
}
